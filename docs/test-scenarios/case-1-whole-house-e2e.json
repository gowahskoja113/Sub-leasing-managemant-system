{
  "name": "Case 1 — Nguyên căn, không cải tạo",
  "baseUrl": "http://localhost:8080/api/v1",
  "auth": "Authorization: Bearer <token>",
  "expectedFinalStatus": "ACTIVE",
  "steps": [
    {
      "step": 1,
      "method": "POST",
      "url": "{{baseUrl}}/properties/draft",
      "body": {
        "propertyName": "Nhà Nguyên Căn Test",
        "address": "10 Lê Lợi",
        "descriptions": "Nhà nguyên căn 2 tầng",
        "zoneId": "<zone-uuid>",
        "areaSize": 100,
        "totalFloor": 2,
        "totalRooms": 4,
        "createdBy": 1,
        "imageUrls": []
      }
    },
    {
      "step": 2,
      "method": "PUT",
      "url": "{{baseUrl}}/properties/{{propertyId}}/equipment-manifest",
      "body": {
        "items": [
          { "catalogId": 1, "quantity": 2, "status": "NEW" },
          { "catalogId": 2, "quantity": 1, "status": "GOOD" }
        ]
      }
    },
    {
      "step": 3,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/inbound-contract",
      "body": {
        "contractCode": "INB-WH-001",
        "ownerName": "Chủ nhà A",
        "totalRentAmount": 2000000000,
        "startDate": "2026-01-01",
        "endDate": "2028-01-01",
        "contractScanUrl": "https://cdn.example.com/inb-wh-001.pdf"
      }
    },
    {
      "step": 4,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/onboarding-options",
      "body": {
        "wholeHouse": true,
        "hasRenovation": false
      }
    },
    {
      "step": 5,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/rooms",
      "note": "Lặp 4 lần — không gán TB, không cần maxOccupants",
      "repeat": [
        { "roomNumber": "T1-P1", "area": 20, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Tầng 1 phòng 1" },
        { "roomNumber": "T1-P2", "area": 18, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Tầng 1 phòng 2" },
        { "roomNumber": "T2-P1", "area": 22, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Tầng 2 phòng 1" },
        { "roomNumber": "T2-P2", "area": 19, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Tầng 2 phòng 2" }
      ]
    },
    {
      "step": 6,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/submit-to-host",
      "expectedPropertyStatus": "PENDING_HOST_REVIEW"
    },
    {
      "step": 7,
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/onboarding-summary"
    },
    {
      "step": 8,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/host-confirm",
      "body": {
        "contingencyPercent": 110,
        "operationManagerId": 42
      },
      "expectedPropertyStatus": "ACTIVE"
    }
  ]
}
