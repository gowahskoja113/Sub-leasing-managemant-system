{
  "name": "Case 3 — Chia phòng, không cải tạo",
  "baseUrl": "http://localhost:8080/api/v1",
  "auth": "Authorization: Bearer <token>",
  "expectedFinalStatus": "ACTIVE",
  "steps": [
    {
      "step": 1,
      "method": "POST",
      "url": "{{baseUrl}}/properties/draft",
      "body": {
        "propertyName": "Nhà Chia Phòng Test",
        "address": "20 Pasteur",
        "descriptions": "Chia 3 phòng",
        "zoneId": "<zone-uuid>",
        "areaSize": 90,
        "totalFloor": 1,
        "totalRooms": 3,
        "imageUrls": []
      }
    },
    {
      "step": 2,
      "method": "PUT",
      "url": "{{baseUrl}}/properties/{{propertyId}}/equipment-manifest",
      "body": {
        "items": [
          { "catalogId": 1, "quantity": 3, "status": "NEW" }
        ]
      }
    },
    {
      "step": 3,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/inbound-contract",
      "body": {
        "contractCode": "INB-RM-001",
        "ownerName": "Chủ nhà B",
        "totalRentAmount": 1500000000,
        "startDate": "2026-01-01",
        "endDate": "2028-01-01",
        "contractScanUrl": "https://cdn.example.com/inb-rm-001.pdf"
      }
    },
    {
      "step": 4,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/onboarding-options",
      "body": {
        "wholeHouse": false,
        "hasRenovation": false
      }
    },
    {
      "step": 5,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/rooms",
      "repeat": [
        { "roomNumber": "P101", "area": 15, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Phòng 1" },
        { "roomNumber": "P102", "area": 16, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Phòng 2" },
        { "roomNumber": "P103", "area": 14, "propertyType": "INDIVIDUAL_ROOM", "structureDescription": "Phòng 3" }
      ]
    },
    {
      "step": 6,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/equipments/assign",
      "repeat": [
        {
          "catalogId": 1,
          "quantity": 1,
          "status": "NEW",
          "source": "INITIAL_HANDOVER",
          "roomId": "<roomId-P101>"
        },
        {
          "catalogId": 1,
          "quantity": 1,
          "status": "NEW",
          "source": "INITIAL_HANDOVER",
          "roomId": "<roomId-P102>"
        },
        {
          "catalogId": 1,
          "quantity": 1,
          "status": "NEW",
          "source": "INITIAL_HANDOVER",
          "roomId": "<roomId-P103>"
        }
      ]
    },
    {
      "step": 7,
      "method": "GET",
      "url": "{{baseUrl}}/properties/{{propertyId}}/equipment-manifest",
      "expectedResponse": [
        { "catalogId": 1, "status": "NEW", "quantity": 3, "assignedCount": 3 }
      ]
    },
    {
      "step": 8,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/submit-to-host",
      "expectedPropertyStatus": "PENDING_HOST_REVIEW"
    },
    {
      "step": 9,
      "method": "POST",
      "url": "{{baseUrl}}/properties/{{propertyId}}/host-confirm",
      "body": {
        "contingencyPercent": 110,
        "operationManagerId": "<manager-uuid-from-GET-user-managers>",
        "roomPrices": [
          { "roomId": "<roomId-P101>", "price": 3500000 },
          { "roomId": "<roomId-P102>", "price": 3200000 },
          { "roomId": "<roomId-P103>", "price": 3000000 }
        ]
      },
      "expectedPropertyStatus": "ACTIVE"
    }
  ]
}
